# Copy to .env and replace secret values before running docker compose.

# LLM Guard API
AUTH_TOKEN=change-me
HOST_APP_PORT=8000
APP_WORKERS=1
APP_NAME=Detailed LLM Guard API

# Docker build
LLM_GUARD_IMAGE=llm-guard:latest
LLM_GUARD_API_IMAGE=laiyer/llm-guard-api:latest
PRELOAD_MODELS=true
RUN_OFFLINE=false

# Request-scoped scanner cache
SCANNER_CACHE_TTL_SECONDS=172800

# Runtime model offline mode
HF_HUB_OFFLINE=false
TRANSFORMERS_OFFLINE=false
HF_DATASETS_OFFLINE=false

# Tracing
TRACING_EXPORTER=otel_http
TRACING_OTEL_ENDPOINT=
OTEL_EXPORTER_OTLP_TRACES_HEADERS=x-project-name=llm-guard
TRACE_HEADER_DEBUG=false

# Phoenix Cloud example. Use the Hostname from your Phoenix Settings page.
# It usually includes your space, for example:
# TRACING_OTEL_ENDPOINT=https://app.phoenix.arize.com/s/your-space-name/v1/traces
# Spaces in the Authorization header must be URL-encoded as %20.
# OTEL_EXPORTER_OTLP_TRACES_HEADERS=authorization=Bearer%20your-phoenix-api-key,x-project-name=llm-guard

# Local Phoenix sidecar example.
# TRACING_OTEL_ENDPOINT=http://phoenix:6006/v1/traces

# Arize AX example.
# TRACING_OTEL_ENDPOINT=https://otlp.arize.com/v1/traces
# OTEL_EXPORTER_OTLP_TRACES_HEADERS=arize-space-id=U3BhY2U6MjY2MDg6RDMwbg==,arize-api-key=your-arize-api-key

# Local Phoenix image settings, if you add a Phoenix service to compose.yaml.
PHOENIX_IMAGE=arizephoenix/phoenix:latest
PHOENIX_PORT=6006
PHOENIX_GRPC_PORT=4317
