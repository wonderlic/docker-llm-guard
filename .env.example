# Copy to .env and replace secret values before running docker compose.

# LLM Guard API
AUTH_TOKEN=change-me
HOST_APP_PORT=8000
APP_WORKERS=1
APP_NAME=Detailed LLM Guard API

# Docker build
LLM_GUARD_IMAGE=llm-guard:latest
LLM_GUARD_API_IMAGE=laiyer/llm-guard-api:latest
PRELOAD_MODELS=true
RUN_OFFLINE=false

# Request-scoped scanner cache
SCANNER_CACHE_TTL_SECONDS=172800

# Runtime model offline mode
HF_HUB_OFFLINE=false
TRANSFORMERS_OFFLINE=false
HF_DATASETS_OFFLINE=false

# Tracing
TRACING_EXPORTER=otel_http
TRACING_OTEL_ENDPOINT=http://phoenix:6006/v1/traces
OTEL_EXPORTER_OTLP_TRACES_HEADERS=x-project-name=llm-guard
TRACE_HEADER_DEBUG=false

# Set PHOENIX_API_VERSION=phoenix for open-source Phoenix.
# When phoenix is enabled and both PHOENIX_TRACING_COLLECTOR_ENDPOINT and
# TRACING_OTEL_ENDPOINT are unset, the API uses http://phoenix:6006/v1/traces.
# Set PHOENIX_API_KEY only when sending to a Phoenix endpoint that requires auth.
# Set PHOENIX_API_VERSION=arize-ax to route traces to Arize AX.
# When arize-ax is enabled and TRACING_OTEL_ENDPOINT is unset or left at the
# compose local-Phoenix default, the API uses https://otlp.arize.com/v1/traces.
# Set PHOENIX_TRACING_COLLECTOR_ENDPOINT only when overriding the AX endpoint.
PHOENIX_API_VERSION=phoenix
PHOENIX_API_KEY=
PHOENIX_SPACE_ID=
PHOENIX_SPACE_KEY=
PHOENIX_TRACING_COLLECTOR_ENDPOINT=
PHOENIX_TRACING_PROJECT_NAME=llm-guard

# Phoenix Cloud example. Use the Hostname from your Phoenix Settings page.
# It usually includes your space, for example:
# TRACING_OTEL_ENDPOINT=https://app.phoenix.arize.com/s/your-space-name/v1/traces
# Spaces in the Authorization header must be URL-encoded as %20.
# OTEL_EXPORTER_OTLP_TRACES_HEADERS=authorization=Bearer%20your-phoenix-api-key,x-project-name=llm-guard

# Arize AX example.
# PHOENIX_API_VERSION=arize-ax
# PHOENIX_SPACE_ID=U3BhY2U6MjY2MDg6RDMwbg==
# PHOENIX_SPACE_KEY=your-space-key
# PHOENIX_API_KEY=your-arize-api-key
# PHOENIX_TRACING_PROJECT_NAME=llm-guard

# Local Phoenix sidecar
PHOENIX_IMAGE=arizephoenix/phoenix:latest
PHOENIX_PORT=6006
PHOENIX_GRPC_PORT=4317
